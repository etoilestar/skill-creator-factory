services:
  backend:
    build:
      context: .
      dockerfile: backend/Dockerfile
    ports:
      - "58000:8000"
      - "52222:22"  # SSH端口映射
    volumes:
      - ./kernel:/app/kernel:ro   # skill-creator kernel (read-only)
      - ./skills:/app/skills       # user skill library (read-write)
      - ./backend:/app/backend 
    environment:
      # Point to the LLM running on the host machine.
      # Ollama default : http://host.docker.internal:11434
      # LM Studio default: http://host.docker.internal:1234
      - LLM_BASE_URL=${LLM_BASE_URL:-http://host.docker.internal:11434}
      - DEFAULT_MODEL=${DEFAULT_MODEL:-qwen3:30b}
      - TEXT_MODEL=${TEXT_MODEL:-qwen3:30b}
      - CODE_MODEL=${CODE_MODEL:-qwen3-coder:30b}
      - PLANNER_MODEL=${PLANNER_MODEL:-qwen3:30b-instruct}
      - VALIDATOR_MODEL=${VALIDATOR_MODEL:-qwen3:8b}
      - IMAGE_MODEL=${IMAGE_MODEL:-qwen3-vl:32b}
      - VISION_MODEL=${VISION_MODEL:-qwen3-vl:32b}
      - SKILL_COMMAND_TIMEOUT=${SKILL_COMMAND_TIMEOUT:-180}
      - LLM_TIMEOUT_SECONDS=${LLM_TIMEOUT_SECONDS:-6000}
      - OPENAI_API_KEY=${OPENAI_API_KEY:-}
      - LLM_API_KEY=${LLM_API_KEY:-}
      - MODEL_ROUTING_JSON=${MODEL_ROUTING_JSON:-}
      - MODEL_ACK_STRICT=${MODEL_ACK_STRICT:-false}
      - TEMPERATURE=${TEMPERATURE:-}
      - MAX_TOKENS=${MAX_TOKENS:-}
# Makes host.docker.internal resolve to the host on Linux as well
    extra_hosts:
      - "host.docker.internal:host-gateway"
    restart: unless-stopped

  frontend:
    build:
      context: ./frontend
      dockerfile: Dockerfile
    ports:
      - "5173:80"
    depends_on:
      - backend
    restart: unless-stopped
