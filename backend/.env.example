# URL of the LLM backend
# Local Ollama:      http://localhost:11434
# Local LM Studio:   http://localhost:1234
# OpenAI:            https://api.openai.com
LLM_BASE_URL=http://localhost:11434

# Model to use by default
# Local example:  llama3.2
# OpenAI example: gpt-4o
DEFAULT_MODEL=llama3.2

# OpenAI API key -- required when LLM_BASE_URL points to an OpenAI-compatible
# cloud API (e.g. api.openai.com, api.gpt.ge).  Leave commented out for local
# backends (Ollama, LM Studio).
# OPENAI_API_KEY=sk-...
